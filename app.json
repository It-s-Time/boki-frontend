{
  "expo": {
    "name": "BOKI",
    "slug": "BOKI",
    "scheme": "boki",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.boki.app"
    },
    "android": {
      "package": "com.boki.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "사진을 첨부하려면 갤러리 접근 권한이 필요합니다."
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b8ebc1cd-9fcd-4200-b80c-5988ce7f4870"
      }
    },
    "owner": "cho22"
  }
}
