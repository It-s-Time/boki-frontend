{
  "expo": {
    "name": "BOKI",
    "slug": "BOKI",
    "scheme": "boki",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "사진을 첨부하려면 갤러리 접근 권한이 필요합니다."
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ]
  }
}
